# Copy to .env for local development. NEVER commit a real .env.

# --- Core ---
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
PUBLIC_BASE_URL=http://localhost:8000

# --- Database ---
# Local dev: the gbd_app NON-superuser role (so RLS is actually enforced).
# Production: a Supabase SESSION-mode connection string (port 5432 / direct),
# NOT the transaction pooler (6543), which breaks per-request SET LOCAL GUCs.
DATABASE_URL=postgres://gbd_app:gbd_app@localhost:5432/gbd

# --- Auth ---
# Session login via django.contrib.auth. Create the first GBD admin with:
#   python manage.py createsuperuser
# Provision a client account with:
#   python manage.py create_client_account --name "Acme U" --username acme --password ...

# --- Storage ---
# local    -> filesystem adapter (no Supabase needed)
# supabase -> Supabase Storage (set the SUPABASE_* vars below)
STORAGE_BACKEND=local
STORAGE_BUCKET=gbd-procurement
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_KEY=sb_secret_...   # service_role key (Settings -> API). SECRET, server-side only.
#                                      # NOT the sb_publishable_/anon key — that can't do server ops.

# --- Limits ---
MAX_UPLOAD_BYTES=104857600
